{
  "name": "fairscan-ai",
  "version": "1.0.0",
  "description": "FairScan AI Bias Auditor - Detect, Analyze & Mitigate AI Model Bias",
  "private": true,
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview",
    "backend": "cd backend && uv run main.py",
    "all": "concurrently \"npm run backend\" \"npm run dev\""
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "vite": "^8.0.10"
  }
}
